
---
const navItems = [
  { href: '#home',       label: 'Inicio',      key: 'home' },
  { href: '#about',      label: 'Sobre mí',    key: 'about' },
  { href: '#skills',     label: 'Skills',      key: 'skills' },
  { href: '#experience', label: 'Experiencia', key: 'experience' },
  { href: '#projects',   label: 'Proyectos',   key: 'projects' },
  { href: '#contact',    label: 'Contacto',    key: 'contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-gray-200/50 dark:border-gray-800/50 transition-colors duration-300 ">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex justify-between items-center">

      <!-- Izquierda: logo -->
      <div class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-blue-500 bg-clip-text text-transparent">
        &lt;Dev/&gt;
      </div>

      <!-- Centro: navegación desktop -->
      <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 space-x-8 ">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link text-gray-700 dark:text-gray-300 hover:text-purple-400 transition-all duration-300 relative group">
            <span data-i18n={`nav.${item.key}`}>{item.label}</span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-purple-400 transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </div>

      <!-- Derecha: toggle (desktop) + menú móvil (mobile) -->
      <div class="flex items-center gap-2">
        <!-- Toggle idioma (desktop) -->
        <button
          class="lang-toggle-btn hidden md:flex items-center justify-center w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/25 text-emerald-400 font-bold text-sm hover:bg-emerald-500/20 hover:border-emerald-400/60 hover:text-emerald-300 hover:shadow-lg hover:shadow-emerald-500/30 hover:scale-110 transition-all duration-300"
          aria-label="Cambiar idioma"
        >EN</button>

        <!-- Toggle visible solo en desktop -->
        <button
          id="theme-toggle-desktop"
          class="theme-toggle-btn hidden md:flex p-2 rounded-xl border transition-all duration-300 hover:scale-110 hover:shadow-lg"
          aria-label="Cambiar tema"
        >
          <svg class="theme-icon-sun w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
          </svg>
          <svg class="theme-icon-moon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
        </button>

        <!-- Botón menú móvil -->
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-xl bg-purple-500/10 border border-purple-500/25 text-purple-400 hover:bg-purple-500/20 transition-all duration-300">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        </button>
      </div>
    </div>

    <!-- Menú móvil -->
    <div id="mobile-menu" class="md:hidden hidden mt-4 pb-4 border-t border-gray-200/50 dark:border-gray-800/50 transition-colors duration-300">
      <div class="flex flex-col space-y-4 pt-4">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link text-gray-700 dark:text-gray-300 hover:text-purple-400 transition-colors px-2 py-1">
            <span data-i18n={`nav.${item.key}`}>{item.label}</span>
          </a>
        ))}

        <!-- Toggles idioma + tema (mobile) — misma fila, centrados -->
        <div class="pt-2 border-t border-gray-200/50 dark:border-gray-800/50 flex justify-center gap-3">
          <!-- Idioma -->
          <button
            class="lang-toggle-btn flex items-center justify-center w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/25 text-emerald-400 font-bold text-sm hover:bg-emerald-500/20 hover:border-emerald-400/60 hover:text-emerald-300 hover:shadow-lg hover:shadow-emerald-500/30 hover:scale-110 transition-all duration-300"
            aria-label="Cambiar idioma"
          >EN</button>

          <!-- Tema -->
          <button
            id="theme-toggle-mobile"
            class="theme-toggle-btn flex items-center justify-center w-10 h-10 rounded-xl border transition-all duration-300 hover:scale-110 hover:shadow-lg"
            aria-label="Cambiar tema"
          >
            <svg class="theme-icon-sun w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
            </svg>
            <svg class="theme-icon-moon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  @reference 'tailwindcss';

  .nav-link.active {
    color: rgb(192 132 252); /* purple-400 */
  }
</style>

<script>
  // Toggle tema — aplica a ambos botones (desktop + mobile)
  function updateThemeUI(isDark: boolean) {
    // Iconos sol/luna
    document.querySelectorAll('.theme-icon-sun').forEach(el => {
      (el as HTMLElement).style.display = isDark ? 'block' : 'none';
    });
    document.querySelectorAll('.theme-icon-moon').forEach(el => {
      (el as HTMLElement).style.display = isDark ? 'none' : 'block';
    });
    // Texto del menú móvil
    document.querySelectorAll('.theme-label').forEach(el => {
      el.textContent = isDark ? 'Modo claro' : 'Modo oscuro';
    });
    // Estilo de botones tema: amber (sol) en oscuro, indigo (luna) en claro
    const colorRx = /bg-\S+\/10|border-\S+\/25|text-\S+400|hover:bg-\S+\/20|hover:border-\S+\/60|hover:text-\S+300|hover:shadow-\S+\/30/g;
    const darkClasses = ['bg-amber-500/10','border-amber-500/25','text-amber-400','hover:bg-amber-500/20','hover:border-amber-400/60','hover:text-amber-300','hover:shadow-amber-500/30'];
    const lightClasses = ['bg-indigo-500/10','border-indigo-500/25','text-indigo-400','hover:bg-indigo-500/20','hover:border-indigo-400/60','hover:text-indigo-300','hover:shadow-indigo-500/30'];

    ['theme-toggle-desktop', 'theme-toggle-mobile'].forEach(id => {
      const btn = document.getElementById(id);
      if (!btn) return;
      btn.className = btn.className.replace(colorRx, '').trim();
      btn.classList.add(...(isDark ? darkClasses : lightClasses));
    });
  }

  function applyTheme(isDark: boolean) {
    document.documentElement.classList.toggle('dark', isDark);
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateThemeUI(isDark);
  }

  // Inicializar UI según el tema actual
  const initDark = document.documentElement.classList.contains('dark');
  updateThemeUI(initDark);

  document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const isDark = !document.documentElement.classList.contains('dark');
      applyTheme(isDark);
    });
  });

  // Menú móvil
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Scroll suave
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      const target = href ? document.querySelector(href) : null;
      if (target) {
        window.scrollTo({ top: target.offsetTop - 80, behavior: 'smooth' });
      }
      if (window.innerWidth < 768) {
        mobileMenu?.classList.add('hidden');
      }
    });
  });

  // Resaltar sección activa
  window.addEventListener('scroll', () => {
    const sections = document.querySelectorAll('section[id]');
    const scrollPos = window.scrollY + 100;

    sections.forEach(section => {
      const sectionTop = section.offsetTop;
      const sectionHeight = section.offsetHeight;
      const sectionId = section.getAttribute('id');

      if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
        document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
        document.querySelector(`.nav-link[href="#${sectionId}"]`)?.classList.add('active');
      }
    });
  });
</script>
