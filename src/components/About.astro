---
import { Image } from 'astro:assets';
import keoveloper from '../assets/keo.png';

---

<section id="about" class="py-20 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        <span class="bg-gradient-to-r from-purple-400 to-blue-500 bg-clip-text text-transparent">
          <span data-i18n="about.title">Sobre Mí</span>
        </span>
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        <span data-i18n="about.subtitle">Conoce más sobre mi pasión por el desarrollo y mi trayectoria profesional</span>
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Imagen/Avatar -->
      <div class="fade-in flex justify-center lg:justify-start">
        <div class="relative group">
          <div class="w-full max-w-xs aspect-[2/3] rounded-2xl bg-gradient-to-br from-purple-400/20 to-blue-500/20 p-1 rotate-3 group-hover:rotate-6 transition-transform duration-300">
            <div class="w-full h-full rounded-2xl bg-gradient-to-r from-gray-300 to-gray-500 flex items-center justify-center overflow-hidden">
              <Image
                src={keoveloper}
                alt="Avatar de Diego Octavio Campos Valerio"
                class="w-full h-full object-cover"/>
            </div>
          </div>
          
          <!-- Decorative elements -->
          <div class="absolute -top-4 -right-4 w-20 h-20 bg-purple-500/10 rounded-full blur-xl"></div>
          <div class="absolute -bottom-4 -left-4 w-16 h-16 bg-blue-500/10 rounded-full blur-xl"></div>
        </div>
      </div>

      <!-- Contenido -->
      <div class="fade-in space-y-6">
        <div class="prose prose-invert max-w-none">
          <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
            <span data-i18n="about.p1a">¡Hola! Soy un desarrollador Full Stack apasionado por crear soluciones digitales innovadoras. Con más de</span>
            <span class="text-purple-400 font-semibold"> 3 años </span>
            <span data-i18n="about.p1b">de experiencia en el desarrollo web, me especializo en transformar ideas complejas en aplicaciones funcionales y atractivas.</span>
          </p>

          <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed mb-6" data-i18n="about.p2">
            Mi enfoque se centra en escribir código limpio, escalable y mantenible,
            siempre buscando las mejores prácticas y tecnologías más actuales del mercado.
            Disfruto especialmente trabajando en equipos colaborativos donde puedo aportar
            mi creatividad y conocimientos técnicos.
          </p>

          <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed" data-i18n="about.p3">
            Cuando no estoy programando, me gusta mantenerme actualizado con las últimas
            tendencias tecnológicas, asi como de las noticias de lo que sucede en este ambito.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8">
          <div class="text-center p-4 rounded-lg bg-gray-100/80 dark:bg-gray-800/50 border border-gray-200/80 dark:border-gray-700/50 hover:border-purple-500/30 transition-colors">
            <div class="text-2xl font-bold text-purple-400 mb-1">5+</div>
            <div class="text-sm text-gray-600 dark:text-gray-400" data-i18n="about.statsProjects">Proyectos</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-gray-100/80 dark:bg-gray-800/50 border border-gray-200/80 dark:border-gray-700/50 hover:border-purple-500/30 transition-colors">
            <div class="text-2xl font-bold text-purple-400 mb-1">3+</div>
            <div class="text-sm text-gray-600 dark:text-gray-400" data-i18n="about.statsExp">Años Exp.</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-gray-100/80 dark:bg-gray-800/50 border border-gray-200/80 dark:border-gray-700/50 hover:border-purple-500/30 transition-colors">
            <div class="text-2xl font-bold text-purple-400 mb-1">3+</div>
            <div class="text-sm text-gray-600 dark:text-gray-400" data-i18n="about.statsCisco">Cisco Certif.</div>
          </div>
          <div class="text-center p-4 rounded-lg bg-gray-100/80 dark:bg-gray-800/50 border border-gray-200/80 dark:border-gray-700/50 hover:border-purple-500/30 transition-colors">
            <div class="text-2xl font-bold text-purple-400 mb-1">24/7</div>
            <div class="text-sm text-gray-600 dark:text-gray-400" data-i18n="about.statsSupport">Soporte</div>
          </div>
        </div>

        <!-- Call to Action -->
        <div class="pt-6">
          <a 
            href="#contact" 
            class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-500 to-blue-600 rounded-lg font-semibold transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-emerald-500/25"
          >
            <span data-i18n="about.cta">Trabajemos juntos</span>
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
